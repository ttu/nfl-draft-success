{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--headless",
        "--caps",
        "vision",
        "--viewport-size",
        "1280x900"
      ]
    }
  },
  "permissions": {
    "allow": ["mcp__plugin_playwright_playwright__browser_console_messages"]
  }
}
